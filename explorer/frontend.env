# Minimal envs to run Blockscout frontend against local backend.
NEXT_PUBLIC_APP_PROTOCOL=http
NEXT_PUBLIC_APP_HOST=localhost
NEXT_PUBLIC_APP_PORT=4000
NEXT_PUBLIC_APP_ENV=development

NEXT_PUBLIC_API_PROTOCOL=http
# Inside Docker network, use the backend service name (not localhost).
NEXT_PUBLIC_API_HOST=blockscout
NEXT_PUBLIC_API_PORT=4000
NEXT_PUBLIC_API_WEBSOCKET_PROTOCOL=ws
NEXT_PUBLIC_API_BASE_PATH=/

# Required network identity
NEXT_PUBLIC_NETWORK_NAME=KryptaFlow Local
NEXT_PUBLIC_NETWORK_ID=31337
NEXT_PUBLIC_NETWORK_CURRENCY_NAME=KFL
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL=KFL
NEXT_PUBLIC_NETWORK_CURRENCY_DECIMALS=18
NEXT_PUBLIC_NETWORK_RPC_URL=http://host.docker.internal:8545

# Disable "add network/token to wallet" for local HTTP setup
NEXT_PUBLIC_WEB3_WALLETS=none

# Keep these pointing to Blockscout public services (frontend expects them).
NEXT_PUBLIC_CONTRACT_INFO_API_HOST=https://contracts-info.services.blockscout.com
NEXT_PUBLIC_ADMIN_SERVICE_API_HOST=https://admin-rs.services.blockscout.com
NEXT_PUBLIC_METADATA_SERVICE_API_HOST=https://metadata.services.blockscout.com
NEXT_PUBLIC_NAME_SERVICE_API_HOST=https://bens.services.blockscout.com
NEXT_PUBLIC_VISUALIZE_API_HOST=https://visualizer.services.blockscout.com
NEXT_PUBLIC_STATS_API_HOST=https://stats.services.blockscout.com
NEXT_PUBLIC_REWARDS_SERVICE_API_HOST=https://merits.blockscout.com

